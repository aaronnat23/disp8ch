# Model Provider API Keys
# Leave blank by default. Add keys through the web onboarding flow or your local .env file.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
QWEN_API_KEY=
DASHSCOPE_API_KEY=
XAI_API_KEY=

# Local Provider URLs
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
OLLAMA_BASE_URL=http://localhost:11434
VLLM_API_KEY=
VLLM_BASE_URL=http://127.0.0.1:8000/v1
SGLANG_API_KEY=
SGLANG_BASE_URL=http://127.0.0.1:30000/v1

# Optional local-model advisor overrides
# Semicolon-separated on Windows. Colon-separated on Linux/macOS.
DISP8CH_MODEL_DIRS=
DISP8CH_LLAMACPP_DIR=

# Optional Computer Use beta
# Install Cua with the app by using --with-computer-use or DISP8CH_WITH_COMPUTER_USE=1.
DISP8CH_ENABLE_COMPUTER_USE=0
DISP8CH_CUA_DRIVER_CMD=
DISP8CH_CUA_TELEMETRY=0

# Channel Tokens
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
WHATSAPP_AUTO_CONNECT=true

# Server Configuration
WS_PORT=3101
DATABASE_PATH=./data/disp8ch.db
MEMORY_PATH=./data/memories
ENCRYPTION_KEY=
SECRETS_MASTER_KEY=

# Google OAuth2 SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=localhost:3100
AUTH_SECRET=
