{
  "name": "disp8ch",
  "version": "1.1.1",
  "private": true,
  "description": "Local-first AI workspace for chat, visual workflows, agent teams, memory, boards, design, and automation.",
  "license": "MIT",
  "homepage": "https://github.com/aaronnat23/disp8ch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aaronnat23/disp8ch.git"
  },
  "bugs": {
    "url": "https://github.com/aaronnat23/disp8ch/issues"
  },
  "main": ".desktop/main.cjs",
  "packageManager": "pnpm@10.30.2",
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "dpc": "./scripts/cli-bin.js"
  },
  "scripts": {
    "dev": "concurrently \"next dev -p 3100\" \"tsx server/ws.ts\"",
    "dev:warm": "tsx scripts/dev-warmup.ts",
    "build": "next build",
    "start": "concurrently \"next start -p 3100\" \"tsx server/ws.ts\"",
    "setup": "tsx scripts/setup.ts",
    "runtime:health": "tsx scripts/runtime-health.ts",
    "runtime:start": "tsx scripts/runtime-manager.ts",
    "install:test": "tsx scripts/install-paths-regression.ts && tsx scripts/portable-node-regression.ts && tsx scripts/runtime-manager-regression.ts && tsx scripts/install-doctor-regression.ts && tsx scripts/install-update-regression.ts && tsx scripts/installer-script-regression.ts && tsx scripts/onboarding-provider-regression.ts && tsx scripts/desktop-update-regression.ts && tsx scripts/desktop-data-import-regression.ts && tsx scripts/desktop-release-manifest-regression.ts && tsx scripts/package-manager-manifests-regression.ts && tsx scripts/desktop-dist-regression.ts",
    "desktop:build": "tsx scripts/desktop-build.ts",
    "desktop:standalone-build": "tsx scripts/desktop-standalone-build.ts",
    "desktop:dev": "pnpm desktop:build && electron .desktop/main.cjs --dev",
    "desktop:pack": "pnpm desktop:standalone-build && pnpm desktop:build && pnpm desktop:stage && electron-builder --dir",
    "desktop:dist": "tsx scripts/desktop-dist.ts",
    "desktop:smoke": "pnpm desktop:standalone-build && pnpm desktop:build && pnpm desktop:stage && tsx scripts/desktop-launch-smoke.ts",
    "desktop:packaged-smoke": "tsx scripts/desktop-packaged-health-smoke.ts",
    "desktop:installer-smoke": "tsx scripts/desktop-installer-smoke.ts",
    "test": "tsx scripts/test.ts",
    "test:release": "tsx scripts/release-regression.ts",
    "test:ui-medium": "tsx scripts/local-ui-medium-regression.ts",
    "export:public": "node scripts/export-public-release.mjs",
    "playwright:install": "playwright install chromium",
    "playwright:install:linux": "playwright install --with-deps chromium",
    "dpc": "node --import tsx ./scripts/cli.ts",
    "link-cli": "npm link",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "next lint",
    "desktop:stage": "tsx scripts/desktop-stage.ts",
    "desktop:manifest": "tsx scripts/desktop-release-manifest.ts",
    "desktop:package-manifests": "tsx scripts/package-manager-manifests.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.43.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-dropdown-menu": "^2.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@slack/socket-mode": "^2.0.5",
    "@slack/web-api": "^7.14.1",
    "@types/nodemailer": "^7.0.11",
    "@whiskeysockets/baileys": "^6.7.0",
    "@xenova/transformers": "^2.17.2",
    "@xyflow/react": "^12.0.0",
    "better-sqlite3": "^11.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "croner": "^10.0.1",
    "discord.js": "^14.25.1",
    "drizzle-orm": "^0.38.0",
    "expr-eval": "^2.0.2",
    "grammy": "^1.40.1",
    "has-flag": "^5.0.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "nanoid": "^5.0.0",
    "next": "^14.2.0",
    "nodemailer": "^8.0.1",
    "openai": "^4.73.0",
    "pdfjs-dist": "^4.8.69",
    "playwright": "^1.58.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "0.32.6",
    "sqlite-vec": "0.1.7-alpha.2",
    "supports-color": "^9.4.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0",
    "undici": "^6.21.3",
    "ws": "^8.18.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@clack/prompts": "^0.8.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.1.0",
    "debug": "^4.4.3",
    "drizzle-kit": "^0.30.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver"
    ]
  }
}
